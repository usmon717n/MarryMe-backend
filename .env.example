# Database (Railway Postgres dan olinadi)
DATABASE_URL="postgresql://user:password@host:5432/railway"
DIRECT_URL="postgresql://user:password@host:5432/railway"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=production

# Frontend URL (CORS uchun)
CLIENT_URL="https://marry-me-frontend.vercel.app"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
